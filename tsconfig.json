{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"]  
  },
  "include": [
    "electron/**/*.ts",
    "playwright/**/*.ts",
    "tests/**/*.ts",
    "ui/**/*"
  ]
}
